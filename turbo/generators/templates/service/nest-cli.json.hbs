{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true{{#if includeDatabase}},
    "assets": [
      {
        "include": "../generated/**/*",
        "outDir": "dist/generated"
      }
    ],
    "watchAssets": true{{/if}}
  }
}
