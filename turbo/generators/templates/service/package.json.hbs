{
  "name": "@hive/{{name}}-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.js"{{#if includeDatabase}},
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"{{/if}}{{#if includeSeed}},
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"{{/if}}
  },
  "dependencies": {
    "@hive/common": "workspace:*",
    "@hive/identity": "workspace:*",
    "@hive/registry": "workspace:*",
    "@hive/utils": "workspace:*",
    "@itgorillaz/configify": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "nestjs-zod": "5.0.0-beta.20250806T023752",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.0.15"{{#if includeGrpc}},
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "@hive/{{name}}": "workspace:*",
    "grpc-health-check": "^2.1.0"{{/if}}{{#if includeDatabase}},
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0"{{/if}}
  },
  "devDependencies": {
    "@hive/jest-config": "workspace:*",
    "@hive/typescript-config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"{{#if includeDatabase}},
    "prisma": "^7.8.0"{{/if}}
  }
}
