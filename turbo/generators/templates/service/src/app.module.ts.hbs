import { GlobalRpcExceptionFilter, {{#if includeDatabase}}PrismaModule, {{/if}}QueryBuilderModule } from '@hive/common';
import {
  {{constantCase name}}_HTTP_SERVER_CONFIG_TOKEN,
  {{#if includeGrpc}}{{constantCase name}}_RPC_SERVER_CONFIG_TOKEN,
  {{/if}}{{pascalCase name}}HTTPServerConfigProvider,
  {{#if includeGrpc}}{{pascalCase name}}RPCServerConfigProvider,
  {{/if}}
} from '@hive/{{name}}';
import {
  Endpoint,
  HiveServiceModule,
  RegistryClientConfig,
} from '@hive/registry';
import { ServerConfig } from '@hive/utils';
import { ConfigifyModule } from '@itgorillaz/configify';
import { Module } from '@nestjs/common';
import { ScheduleModule } from '@nestjs/schedule';
{{#if includeDatabase}}import { PrismaPg } from '@prisma/adapter-pg';
{{/if}}import { AppController } from './app.controller';
import { AppService } from './app.service';
{{#if includeDatabase}}import { PrismaConfig } from './prisma/prisma.config';
import { PrismaService } from './prisma/prisma.service';
{{/if}}
@Module({
  imports: [
    ConfigifyModule.forRootAsync({ configFilePath: ['.env', 'package.json'] }),
    ScheduleModule.forRoot(),
    HiveServiceModule.forRoot({
      global: true,
      enableHeartbeat: true,
      services: [],
      client: {
        useFactory: (
          config: RegistryClientConfig,
          http: ServerConfig,
          {{#if includeGrpc}}grpc: ServerConfig,
          {{/if}}
        ) => {
          if (!config) {
            throw new Error('RegistryClientConfig is required');
          }

          return {
            service: {
              metadata: config.metadata ?? {},
              name: config.serviceName,
              version: config.serviceVersion,
              tags: [
                http ? 'http' : undefined,
                {{#if includeGrpc}}grpc ? 'grpc' : undefined,
                {{/if}}
              ].filter(Boolean) as Array<string>,
              endpoints: [
                http
                  ? {
                      host: http.host,
                      port: http.port,
                      protocol: 'http',
                      metadata: {},
                    }
                  : undefined,
                {{#if includeGrpc}}grpc
                  ? {
                      host: grpc.host,
                      port: grpc.port,
                      protocol: 'grpc',
                      metadata: {},
                    }
                  : undefined,
                {{/if}}
              ].filter(Boolean) as Array<Endpoint>,
            },
          };
        },
        inject: [
          RegistryClientConfig,
          {{constantCase name}}_HTTP_SERVER_CONFIG_TOKEN,
          {{#if includeGrpc}}{{constantCase name}}_RPC_SERVER_CONFIG_TOKEN,
          {{/if}}
        ],
        providers: [
          {{pascalCase name}}HTTPServerConfigProvider,
          {{#if includeGrpc}}{{pascalCase name}}RPCServerConfigProvider,
          {{/if}}
        ],
      },
    }),
    QueryBuilderModule.register({ global: true }),
    {{#if includeDatabase}}PrismaModule.forRootAsync({
      global: true,
      service: PrismaService,
      inject: [PrismaConfig],
      useFactory: (config: PrismaConfig) => ({
        adapter: new PrismaPg({ connectionString: config.databaseUrl }),
      }),
    }),
    {{/if}}// TODO: Add feature modules here, e.g.:
    // ItemsModule,
  ],
  controllers: [AppController],
  providers: [AppService, GlobalRpcExceptionFilter],
})
export class AppModule {}
