syntax = 'proto3';

import "common.message.proto";
import "{{name}}.model.proto";

message Query{{pascalCase name}}Request {
    QueryBuilder query_builder = 1;
    optional string search = 2;
    optional string organization_id = 3;
    optional bool include_voided = 4;
    optional RequestContext context = 5;
    // TODO: add domain-specific filter fields
}

message Query{{pascalCase name}}Response {
    repeated {{pascalCase name}} data = 1;
    string metadata = 2;
}

message Get{{pascalCase name}}Request {
    QueryBuilder query_builder = 1;
    string id = 2;
    optional RequestContext context = 3;
}

message Get{{pascalCase name}}Response {
    {{pascalCase name}} data = 1;
    string metadata = 2;
}

message Create{{pascalCase name}}Request {
    QueryBuilder query_builder = 1;
    string name = 2;
    optional string organization_id = 3;
    optional RequestContext context = 4;
    // TODO: add domain-specific create fields
}

message Update{{pascalCase name}}Request {
    QueryBuilder query_builder = 1;
    string id = 2;
    optional string name = 3;
    optional RequestContext context = 4;
    // TODO: add domain-specific update fields
}

message Delete{{pascalCase name}}Request {
    QueryBuilder query_builder = 1;
    string id = 2;
    optional bool purge = 3;
    optional RequestContext context = 4;
}
