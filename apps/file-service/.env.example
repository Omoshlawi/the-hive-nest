# PostgreSQL — file metadata schema
DATABASE_URL=postgresql://user:password@localhost:5432/hive_files

# S3 / MinIO credentials
S3_ACCESS_KEY_ID=your-access-key
S3_SECRETE_ACCESS_KEY_ID=your-secret-key   # note: typo in env var name matches codebase

# S3 endpoint (use http://localhost:9000 for local MinIO)
S3_ENDPOINT=http://localhost:9000

# Bucket names (created in MinIO/S3 before starting)
S3_BUCKET_PUBLIC=hive-files-public
S3_BUCKET_PRIVATE=hive-files-private

# Comma-separated allowed MIME types (optional — see s3.config.ts for defaults)
# ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

# Registry service address (default: 0.0.0.0:4001)
# SERVER_URL=0.0.0.0:4001
