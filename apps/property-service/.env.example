# PostgreSQL — property domain schema
DATABASE_URL=postgresql://user:password@localhost:5432/hive_property

# HTTP port for registry health endpoint (0 = auto-assign a free port)
PORT=0

# gRPC server port (0 = auto-assign a free port)
PROPERTY_GRPC_SERVICE_PORT=0

# Registry service address (default: 0.0.0.0:4001)
# SERVER_URL=0.0.0.0:4001
