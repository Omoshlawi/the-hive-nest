# HTTP server port
PORT=8090

# PostgreSQL — auth/identity schema
DATABASE_URL=postgresql://user:password@localhost:5432/hive_gateway

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:8090
# Comma-separated list of frontend origins allowed to make auth requests
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:1234
# Set to true only in local dev — the Kras proxy strips Origin headers, bypassing CSRF check
# Must be false (or unset) in production
BETTER_AUTH_DISABLE_CSRF_CHECK=false

# Built-in identity gRPC server port (0 = pick a free port)
IDENTITY_SERVICE_PORT=0

# Registry service address (default: 0.0.0.0:4001)
# SERVER_URL=0.0.0.0:4001
