# Redis connection URL
REDIS_DB_URL=redis://user:password@localhost:6379

# gRPC server port (default: 4001 — keep this fixed so other services can find it)
# PORT=4001

# Storage backend: redis_storage | memory_storage
# STORAGE_STRATEGY=redis_storage

# Seconds before a registration without a heartbeat is evicted (0 = never expire)
# SERVICE_TTL=60
