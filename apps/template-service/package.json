    "test:e2e": "jest --config ./test/jest-e2e.js",
    "db": "prisma",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
