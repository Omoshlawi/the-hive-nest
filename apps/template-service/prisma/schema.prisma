generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" // Generated folder must be added to assets for watch and copy to dist folder
}

datasource db {
  provider = "postgresql"
}

// Template engine — only HANDLEBARS supported now, enum future-proofs additional engines
enum TemplateEngine {
  HANDLEBARS
}

// System default templates have organizationId = null.
// Org overrides are stored separately in OrgTemplateOverride.
// Every update snapshots the current state into TemplateVersion before applying changes.
model Template {
  id          String         @id @default(uuid())
  key         String         @unique // e.g. "auth.email.verification"
  type        String // "notification" | "prompt" | "report" | "invoice" | "document"
  name        String
  description String?
  engine      TemplateEngine @default(HANDLEBARS)
  slots       Json // { slotName: "Handlebars string" } — caller defines slot names
  schema      Json? // optional JSON Schema describing required/optional slots (dev-time validation)
  metadata    Json? // type-specific config e.g. { channels: { email: true, sms: false } }
  version     Int            @default(1) // incremented on each update; versions stored in TemplateVersion

  voided    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions  TemplateVersion[]
  overrides OrgTemplateOverride[]

  @@map("templates")
}

// Immutable snapshot of template content at each version.
// Never update these rows — create new ones.
model TemplateVersion {
  id          String   @id @default(uuid())
  templateId  String
  version     Int // matches Template.version at the time of snapshot
  slots       Json
  schema      Json?
  metadata    Json?
  changedById String? // userId — plain String, no FK (cross-service boundary)
  changeNote  String? // optional commit-message style description
  createdAt   DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
  @@map("template_versions")
}

// Per-org override: stores only the slots an org changed.
// At render time, system template slots are merged with these (org slots win on conflict).
model OrgTemplateOverride {
  id             String   @id @default(uuid())
  templateKey    String
  organizationId String
  slots          Json // only the slots this org changed
  metadata       Json? // org-specific metadata overrides
  version        Int      @default(1)

  voided    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template Template                     @relation(fields: [templateKey], references: [key], onDelete: Cascade)
  versions OrgTemplateOverrideVersion[]

  @@unique([templateKey, organizationId])
  @@index([organizationId])
  @@map("org_template_overrides")
}

// Immutable snapshot of org override content at each version.
model OrgTemplateOverrideVersion {
  id          String   @id @default(uuid())
  overrideId  String
  version     Int
  slots       Json
  metadata    Json?
  changedById String?
  changeNote  String?
  createdAt   DateTime @default(now())

  override OrgTemplateOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@unique([overrideId, version])
  @@index([overrideId])
  @@map("org_template_override_versions")
}
